{
  "name": "workitout",
  "version": "1.3.5",
  "description": "WorkItOut desktop mod manager",
  "main": "dist-electron/main/main.js",
  "author": {
    "name": "veeanti"
  },
  "license": "MIT",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "pnpm run build:react && electron-vite build",
    "build:react": "vite build --outDir dist-react",
    "preview": "vite preview",
    "pack": "electron-builder",
    "dist": "pnpm run build && electron-builder"
  },
  "dependencies": {
    "adm-zip": "^0.5.10",
    "axios": "^1.6.0",
    "cheerio": "^1.0.0-rc.12",
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  },
  "devDependencies": {
    "@types/adm-zip": "^0.5.5",
    "@types/node": "^20.19.0",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "^4.3.0",
    "electron": "^35.7.5",
    "electron-builder": "^26.8.1",
    "electron-vite": "^5.0.0",
    "typescript": "^5.6.0",
    "vite": "^6.0.0"
  },
  "build": {
    "appId": "com.workitout.unioncrax",
    "productName": "WorkItOut!",
    "copyright": "veeanti & UnionCrax | 2026",
    "icon": "build/icon.ico",
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "electronDist": "node_modules/electron/dist",
    "files": [
      "dist-electron/**/*",
      "dist-react/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        "nsis",
        "portable",
        "zip"
      ],
      "icon": "build/icon.ico",
      "publisherName": "veeeanti",
      "legalTrademarks": "UnionCrax",
      "signAndEditExecutable": false
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "build/icon.ico",
      "uninstallerIcon": "build/icon.ico",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "WorkItOut!"
    },
    "linux": {
      "target": [
        "AppImage"
      ],
      "icon": "build/icon.png",
      "category": "Utility"
    },
    "publish": {
      "provider": "github",
      "owner": "veeeanti",
      "repo": "WorkItOut"
    }
  },
  "pnpm": {
    "overrides": {
      "undici": "^6.24.1"
    }
  }
}
